<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.samyak.doubletapplayerview.DoubleTapPlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_centerInParent="true"
        android:visibility="visible"
        android:background="@android:color/background_dark"
        app:controller_layout_id="@layout/custom_controller"
        app:player_layout_id="@layout/exo_player_view"
        app:use_controller="true"
        app:resize_mode="fit"
        app:dtpv_controller="@+id/youtube_overlay" />

    <com.samyak.doubletapplayerview.youtube.YouTubeOverlay
        android:id="@+id/youtube_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_centerInParent="true"
        android:visibility="invisible"
        app:yt_playerView="@+id/playerView" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:visibility="visible" />

    <TextView
        android:id="@+id/errorTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="Channel not available now"
        android:textSize="24sp"
        android:visibility="gone"
        android:textColor="@android:color/white" />

    <!-- Left side panel: Brightness control overlay -->
    <LinearLayout
        android:id="@+id/brightness_control_panel"
        android:layout_width="56dp"
        android:layout_height="180dp"
        android:layout_alignParentLeft="true"
        android:layout_centerVertical="true"
        android:layout_marginLeft="24dp"
        android:background="@drawable/player_control_panel_bg"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/brightness_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/brightness_icon"
            android:contentDescription="Brightness" />

        <ProgressBar
            android:id="@+id/brightness_progressbar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="8dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:progressDrawable="@drawable/vertical_progress_drawable"
            android:max="100" />

        <TextView
            android:id="@+id/brightness_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:text="50%" />
    </LinearLayout>

    <!-- Right side panel: Volume control overlay -->
    <LinearLayout
        android:id="@+id/volume_control_panel"
        android:layout_width="56dp"
        android:layout_height="180dp"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"
        android:layout_marginRight="24dp"
        android:background="@drawable/player_control_panel_bg"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/volume_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/volume_icon"
            android:contentDescription="Volume" />

        <ProgressBar
            android:id="@+id/volume_progressbar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="8dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:progressDrawable="@drawable/vertical_progress_drawable"
            android:max="100" />

        <TextView
            android:id="@+id/volume_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:text="50%" />
    </LinearLayout>

    <!-- Disney+/Hotstar style "Next Episode" overlay. Lives outside the auto-hiding
         controller so it can pop up near the end of an episode and stay visible. -->
    <LinearLayout
        android:id="@+id/nextEpisodeOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentRight="true"
        android:layout_alignParentBottom="true"
        android:layout_marginRight="28dp"
        android:layout_marginBottom="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/next_episode_bg"
        android:paddingStart="18dp"
        android:paddingEnd="22dp"
        android:paddingTop="11dp"
        android:paddingBottom="11dp"
        android:clickable="true"
        android:focusable="true"
        android:elevation="12dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginEnd="10dp"
            android:src="@drawable/next_episode_icon"
            android:contentDescription="@string/next_episode_btn"
            app:tint="#111111" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/next_episode_btn"
            android:textColor="#111111"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>
</RelativeLayout>